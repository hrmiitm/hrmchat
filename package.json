{
  "name": "hrmchat",
  "version": "1.0.1",
  "description": "HRMChat - A unified multi-tab desktop app for ChatGPT, Gemini, and Claude",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.hrmchat.app",
    "productName": "HRMChat",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "appx"
      ]
    },
    "appx": {
      "identityName": "hrmchat",
      "publisher": "CN=hrmiitm",
      "publisherDisplayName": "Hritik Roshan Maurya"
    },
    "linux": {
      "target": [
        "deb",
        "snap",
        "AppImage",
        "tar.gz"
      ],
      "category": "Network",
      "executableArgs": [
        "--no-sandbox",
        "--ozone-platform=x11"
      ]
    },
    "snap": {
      "plugs": [
        "default",
        "network-manager",
        "upower-observe",
        "camera",
        "audio-record"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrmiitm/hrmchat.git"
  },
  "keywords": [],
  "author": "HRM IITM <admin@hrmiitm.com>",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hrmiitm/hrmchat/issues"
  },
  "homepage": "https://github.com/hrmiitm/hrmchat#readme",
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}
